{
  "name": "dobbe",
  "version": "0.1.0",
  "description": "AI-powered MCP server that orchestrates Claude Code agents to scan vulnerabilities, fix dependencies, review PRs, generate tests, triage incidents, and track DORA metrics",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dobbe": "dist/bin/install.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "claude",
    "ai",
    "security",
    "vulnerability",
    "code-review",
    "testing",
    "devops",
    "automation",
    "agents",
    "dora-metrics",
    "incident-triage",
    "dependency-management",
    "claude-code"
  ],
  "author": {
    "name": "Naresh Sekar",
    "email": "nareshnavinash@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nareshnavinash/dobbe-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4",
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "@eslint/js": "^9.25.1",
    "typescript-eslint": "^8.31.0"
  }
}
